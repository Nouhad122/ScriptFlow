{
  "name": "scriptflow",
  "version": "1.0.0",
  "description": "AI content generation pipeline - multi-agent architecture",
  "private": true,
  "scripts": {
    "dev:backend": "tsx watch src/index.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "tsc -p tsconfig.json",
    "test:memory": "vitest run src/memory/__tests__",
    "test:ai": "tsx src/scripts/test-ai.ts",
    "test:db": "tsx src/scripts/test-persistence.ts",
    "test:pipeline": "tsx src/scripts/test-pipeline.ts",
    "test:scripts": "tsx src/scripts/test-scripts.ts",
    "test:quality": "tsx src/scripts/test-quality.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@libsql/client": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  }
}
